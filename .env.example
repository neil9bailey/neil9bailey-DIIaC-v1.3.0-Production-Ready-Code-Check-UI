# Root compose environment (used by docker-compose.yml interpolation)
# Copy this file to .env and fill in values. See .env for vendorlogic.io defaults.

# Host ports
RUNTIME_HOST_PORT=8000
BRIDGE_HOST_PORT=3001
FRONTEND_HOST_PORT=5173

# Bridge LLM settings
LLM_INGESTION_ENABLED=false
LLM_STUB_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Entra ID Authentication (Bridge) ────────────────────────────
# Production RS256 mode — validates tokens via Entra OIDC/JWKS:
# AUTH_MODE=entra_jwt_rs256
# ENTRA_ROLE_CLAIM=roles
# ENTRA_EXPECTED_TENANT_ID=<your-tenant-id>
# ENTRA_EXPECTED_AUDIENCE=<your-app-registration-client-id>
# ENTRA_EXPECTED_ISSUERS=https://login.microsoftonline.com/<tenant-id>/v2.0,https://sts.windows.net/<tenant-id>/
#
# Security group OID → DIIaC role mapping:
#   Roles: admin (full access), standard (main UI), customer (deferred)
#   Sub-roles: cto, ciso, architect (future phase)
#
# vendorlogic.io (Admins OID → admin, Standard Users OID → standard):
# ENTRA_GROUP_TO_ROLE_JSON={"81786818-de16-4115-b061-92fce74b00bd":{"role":"admin"},"9c7dd0d4-5b44-4811-b167-e52df21092d8":{"role":"standard"}}
# ENTRA_PRINCIPAL_TO_ROLE_JSON={"b726558d-f1c6-48f7-8a3d-72d5db818d0f":"admin"}
# ENTRA_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
# ENTRA_OIDC_DISCOVERY_URL=https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
#
# Integration-test fallback (HS256 — NOT for production):
# AUTH_MODE=entra_jwt_hs256
# ENTRA_JWT_HS256_SECRET=<test-shared-secret>
