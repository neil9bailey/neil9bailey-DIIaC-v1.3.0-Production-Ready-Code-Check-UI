# Copy to .env locally and set real values. Do NOT commit real secrets.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
GOVERNANCE_BUILD_HASH=local-dev

# Optional runtime hardening
STRICT_DETERMINISTIC_MODE=true
ENFORCE_ADMIN_AUTH=false
ADMIN_API_KEY=change-me-if-enabled
JWT_SECRET=change-me-if-enabled
JWT_ISSUER=diiac
JWT_AUDIENCE=diiac-admin
