# Bridge runtime configuration
PYTHON_BASE_URL=http://127.0.0.1:8000

# LLM orchestration
LLM_INGESTION_ENABLED=true
# Set to true to allow deterministic local fallback when GITHUB_TOKEN is missing
LLM_STUB_ENABLED=false
# Single-provider mode in this release
LLM_PROVIDER_MODE=copilot_only
# Copilot (GitHub Models API) requires a GitHub PAT with models:read scope
GITHUB_TOKEN=
COPILOT_MODEL=gpt-4o

# Entra ID Authentication
# Production mode (RS256 via Entra OIDC/JWKS):
# AUTH_MODE=entra_jwt_rs256
# ENTRA_ROLE_CLAIM=roles
# ENTRA_EXPECTED_TENANT_ID=1384b1c5-2bae-45a1-a4b4-e94e3315eb41
# ENTRA_EXPECTED_AUDIENCE=b726558d-f1c6-48f7-8a3d-72d5db818d0f
# ENTRA_EXPECTED_ISSUERS=https://login.microsoftonline.com/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/v2.0,https://sts.windows.net/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/
# Group-to-role mapping supports legacy flat strings or structured objects:
#   Flat:       {"<oid>": "admin"}
#   Structured: {"<oid>": {"role":"admin"}, "<oid>": {"role":"standard"}, "<oid>": {"subrole":"cto"}}
#
# Roles: admin (full access), standard (main UI, no dashboard/admin), customer (deferred to SaaS phase)
# Sub-roles: cto, ciso, architect (future phase; carried in token for downstream use)
#
# Admins group OID:         81786818-de16-4115-b061-92fce74b00bd
# Standard Users group OID: 9c7dd0d4-5b44-4811-b167-e52df21092d8
# ENTRA_GROUP_TO_ROLE_JSON={"81786818-de16-4115-b061-92fce74b00bd":{"role":"admin"},"9c7dd0d4-5b44-4811-b167-e52df21092d8":{"role":"standard"}}
# ENTRA_PRINCIPAL_TO_ROLE_JSON={"b726558d-f1c6-48f7-8a3d-72d5db818d0f":"admin"}
# ENTRA_OIDC_DISCOVERY_URL=https://login.microsoftonline.com/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/v2.0/.well-known/openid-configuration
# ENTRA_JWKS_URI=https://login.microsoftonline.com/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/discovery/v2.0/keys

# Integration-test fallback (HS256 with shared secret; NOT for production):
# AUTH_MODE=entra_jwt_hs256
# ENTRA_JWT_HS256_SECRET=<test-shared-secret>
