                },
                {
                  "name": "ENTRA_EXPECTED_ISSUERS",
                  "value": "[variables('entraExpectedIssuers')]"
                },
                {
                  "name": "ENTRA_GROUP_TO_ROLE_JSON",
                  "value": "[variables('entraGroupToRoleJson')]"
                },
                {
                  "name": "ENTRA_PRINCIPAL_TO_ROLE_JSON",
                  "value": "[parameters('entraPrincipalToRoleJson')]"
                },
                {
                  "name": "ENTRA_OIDC_DISCOVERY_URL",
                  "value": "[variables('entraOidcUrl')]"
                },
                {
                  "name": "ENTRA_JWKS_URI",
                  "value": "[variables('entraJwksUri')]"
                },
                {
                  "name": "ADMIN_API_TOKEN",
                  "secretRef": "admin-api-token"
                },
                {
                  "name": "GITHUB_TOKEN",
                  "secretRef": "github-token"
                },
                {
                  "name": "BRIDGE_STATE_PATH",
                  "value": "/workspace/state/operations_state.json"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/health",
                    "port": 3001
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/readiness",
                    "port": 3001
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                }
              ],
              "volumeMounts": [
                {
                  "volumeName": "bridge-human-input-volume",
                  "mountPath": "/workspace/artefacts/human-input"
                },
                {
                  "volumeName": "bridge-decision-packs-volume",
                  "mountPath": "/workspace/artefacts/decision-packs"
                },
                {
                  "volumeName": "bridge-state-volume",
                  "mountPath": "/workspace/state"
                },
                {
                  "volumeName": "bridge-ledger-volume",
                  "mountPath": "/workspace/ledger"
                }
              ],
              "resources": {
                "cpu": "[json(parameters('bridgeCpu'))]",
                "memory": "[parameters('bridgeMemory')]"
              }
            }
          ],
          "volumes": [
            {
              "name": "bridge-human-input-volume",
              "storageType": "AzureFile",
              "storageName": "[variables('bridgeHumanInputStorageName')]"
            },
            {
              "name": "bridge-decision-packs-volume",
              "storageType": "AzureFile",
              "storageName": "[variables('bridgeDecisionPacksStorageName')]"
            },
            {
              "name": "bridge-state-volume",
              "storageType": "AzureFile",
              "storageName": "[variables('bridgeStateStorageName')]"
            },
            {
              "name": "bridge-ledger-volume",
              "storageType": "AzureFile",
              "storageName": "[variables('bridgeLedgerStorageName')]"
            }
          ],
          "scale": {
            "minReplicas": "[parameters('bridgeMinReplicas')]",
            "maxReplicas": "[parameters('bridgeMaxReplicas')]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName'))]",
        "[resourceId('Microsoft.App/containerApps', parameters('runtimeAppName'))]"
      ]
    },
    {
      "condition": "[parameters('deployApps')]",
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2023-05-01",
      "name": "[parameters('uiAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName')))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 5173,
            "allowInsecure": false,
            "transport": "auto",
            "customDomains": "[if(empty(parameters('uiCustomDomainCertificateId')), createArray(), createArray(createObject('name', parameters('uiPublicDomain'), 'bindingType', 'SniEnabled', 'certificateId', parameters('uiCustomDomainCertificateId'))))]"
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-11-01-preview').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName'))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "frontend",
              "image": "[format('{0}/{1}/frontend:{2}', reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-11-01-preview').loginServer, parameters('imageRepositoryPrefix'), parameters('frontendImageTag'))]",
              "env": [
                {
                  "name": "APP_ENV",
                  "value": "production"
                },
                {
                  "name": "VITE_API_BASE",
                  "value": "[format('https://{0}.{1}', parameters('bridgeAppName'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2023-05-01').defaultDomain)]"
                },
                {
                  "name": "VITE_LLM_PROVIDER_MODE",
                  "value": "copilot_only"
                },
                {
                  "name": "VITE_ENTRA_CLIENT_ID",
                  "value": "[parameters('entraUiAppId')]"
                },
                {
                  "name": "VITE_ENTRA_TENANT_ID",
                  "value": "[parameters('entraTenantId')]"
                },
                {
                  "name": "VITE_ENTRA_REDIRECT_URI",
                  "value": "[format('https://{0}/auth/callback', parameters('uiPublicDomain'))]"
                },
                {
                  "name": "VITE_ENTRA_GROUP_MAP",
                  "value": "[variables('entraGroupToRoleJson')]"
                }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": {
                    "path": "/",
                    "port": 5173
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                },
                {
                  "type": "Readiness",
                  "httpGet": {
                    "path": "/",
                    "port": 5173
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10,
                  "timeoutSeconds": 5,
                  "failureThreshold": 3
                }
              ],
              "resources": {
                "cpu": "[json(parameters('frontendCpu'))]",
                "memory": "[parameters('frontendMemory')]"
              }
            }
          ],
          "scale": {
            "minReplicas": "[parameters('uiMinReplicas')]",
            "maxReplicas": "[parameters('uiMaxReplicas')]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.App/containerApps', parameters('bridgeAppName'))]",
        "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "dedicatedAcrName": {
      "type": "string",
      "value": "[parameters('containerRegistryName')]"
    },
    "dedicatedAcrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-11-01-preview').loginServer]"
    },
    "dedicatedStorageAccountName": {
      "type": "string",
      "value": "[parameters('storageAccountName')]"
    },
    "dedicatedManagedIdentityId": {
      "type": "string",
      "value": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName'))]"
    },
    "dedicatedManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName')), '2023-01-31').principalId]"
    },
    "dedicatedManagedEnvironmentId": {
      "type": "string",
      "value": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
    },
    "dedicatedManagedEnvironmentDefaultDomain": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2023-05-01').defaultDomain]"
    },
    "sharedKeyVaultId": {
      "type": "string",
      "value": "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', parameters('sharedKeyVaultSubscriptionId'), parameters('sharedKeyVaultResourceGroupName')), 'Microsoft.KeyVault/vaults', parameters('sharedKeyVaultName'))]"
    },
    "sharedKeyVaultUri": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', parameters('sharedKeyVaultSubscriptionId'), parameters('sharedKeyVaultResourceGroupName')), 'Microsoft.KeyVault/vaults', parameters('sharedKeyVaultName')), '2023-07-01').vaultUri]"
    },
    "runtimeInternalBaseUrl": {
      "type": "string",
      "value": "[if(parameters('deployApps'), format('https://{0}.internal.{1}', parameters('runtimeAppName'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2023-05-01').defaultDomain), '')]"
    },
    "bridgeExternalBaseUrl": {
      "type": "string",
      "value": "[if(parameters('deployApps'), format('https://{0}.{1}', parameters('bridgeAppName'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName')), '2023-05-01').defaultDomain), '')]"
    },
    "uiAppFqdn": {
      "type": "string",
      "value": "[if(parameters('deployApps'), reference(resourceId('Microsoft.App/containerApps', parameters('uiAppName')), '2023-05-01').configuration.ingress.fqdn, '')]"
    },
    "dnsCnameHost": {
      "type": "string",
      "value": "[parameters('uiDnsSubdomain')]"
    },
    "dnsCnameTarget": {
      "type": "string",
      "value": "[if(parameters('deployApps'), reference(resourceId('Microsoft.App/containerApps', parameters('uiAppName')), '2023-05-01').configuration.ingress.fqdn, '')]"
    },
    "dnsTxtHost": {
      "type": "string",
      "value": "[format('asuid.{0}', parameters('uiDnsSubdomain'))]"
    },
    "dnsTxtValue": {
      "type": "string",
      "value": "[if(parameters('deployApps'), reference(resourceId('Microsoft.App/containerApps', parameters('uiAppName')), '2023-05-01').customDomainVerificationId, '')]"
    },
    "uiCustomDomain": {
      "type": "string",
      "value": "[parameters('uiPublicDomain')]"
    }
  }
}