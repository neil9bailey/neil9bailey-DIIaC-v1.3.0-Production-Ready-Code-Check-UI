# DIIaC v1.2.0 — Customer Instance Configuration Template
#
# Copy this directory to customer-config/<customer-name>/
# Fill in all REPLACE_WITH_* values.
# These are PUBLIC identifiers — safe to commit. Contains NO secrets.
#
# Customer:    REPLACE_WITH_CUSTOMER_NAME
# Instance ID: REPLACE_WITH_CUSTOMER_ID-prod
# Created:     REPLACE_WITH_DATE
# Platform:    DIIaC v1.2.0

# ── Azure Tenant ──────────────────────────────────────────────────────────────
CUSTOMER_NAME=REPLACE_WITH_CUSTOMER_NAME
CUSTOMER_INSTANCE_ID=REPLACE_WITH_CUSTOMER_ID-prod
AZURE_TENANT_ID=REPLACE_WITH_TENANT_ID
KEY_VAULT_NAME=kv-diiac-REPLACE_WITH_CUSTOMER_ID
AZURE_RESOURCE_GROUP=rg-diiac-prod
AZURE_LOCATION=REPLACE_WITH_AZURE_REGION

# ── Entra ID App Registrations ────────────────────────────────────────────────
ENTRA_API_APP_ID=REPLACE_WITH_API_APP_CLIENT_ID
ENTRA_UI_APP_ID=REPLACE_WITH_UI_APP_CLIENT_ID

# ── Entra ID Groups ───────────────────────────────────────────────────────────
ENTRA_ADMIN_GROUP_ID=REPLACE_WITH_ADMIN_GROUP_OBJECT_ID
ENTRA_STANDARD_GROUP_ID=REPLACE_WITH_STANDARD_GROUP_OBJECT_ID

# ── Derived values (auto-built from above) ────────────────────────────────────
# Update these with the actual REPLACE_WITH_* values resolved
ENTRA_EXPECTED_TENANT_ID=REPLACE_WITH_TENANT_ID
ENTRA_EXPECTED_AUDIENCE=api://REPLACE_WITH_API_APP_CLIENT_ID
ENTRA_EXPECTED_ISSUERS=https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/v2.0,https://sts.windows.net/REPLACE_WITH_TENANT_ID/
ENTRA_GROUP_TO_ROLE_JSON={"REPLACE_WITH_ADMIN_GROUP_OBJECT_ID":{"role":"admin"},"REPLACE_WITH_STANDARD_GROUP_OBJECT_ID":{"role":"standard"}}
ENTRA_OIDC_DISCOVERY_URL=https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/v2.0/.well-known/openid-configuration
ENTRA_JWKS_URI=https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/discovery/v2.0/keys
VITE_ENTRA_CLIENT_ID=REPLACE_WITH_UI_APP_CLIENT_ID
VITE_ENTRA_TENANT_ID=REPLACE_WITH_TENANT_ID
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_ENTRA_GROUP_MAP={"REPLACE_WITH_ADMIN_GROUP_OBJECT_ID":{"role":"admin"},"REPLACE_WITH_STANDARD_GROUP_OBJECT_ID":{"role":"standard"}}
