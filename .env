# DIIaC v1.2.0 — Root compose environment
# Used by docker-compose.yml for variable interpolation.
# This file is gitignored by default but force-tracked for the vendorlogic.io deployment.

# ── Host ports ───────────────────────────────────────────────────
RUNTIME_HOST_PORT=8000
BRIDGE_HOST_PORT=3001
FRONTEND_HOST_PORT=5173

# ── LLM settings ─────────────────────────────────────────────────
LLM_INGESTION_ENABLED=true
LLM_STUB_ENABLED=false
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini
COPILOT_MODEL=gpt-4o

# ── Entra ID Authentication (Bridge) ────────────────────────────
# Production RS256 — validates tokens via Entra OIDC/JWKS
AUTH_MODE=entra_jwt_rs256
ENTRA_ROLE_CLAIM=roles
ENTRA_EXPECTED_TENANT_ID=1384b1c5-2bae-45a1-a4b4-e94e3315eb41
ENTRA_EXPECTED_AUDIENCE=b726558d-f1c6-48f7-8a3d-72d5db818d0f
ENTRA_EXPECTED_ISSUERS=https://login.microsoftonline.com/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/v2.0,https://sts.windows.net/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/

# Security group OID → DIIaC role mapping (vendorlogic.io tenant)
#   Admins group        (81786818-de16-4115-b061-92fce74b00bd) → admin
#   Standard Users group (9c7dd0d4-5b44-4811-b167-e52df21092d8) → standard
ENTRA_GROUP_TO_ROLE_JSON={"81786818-de16-4115-b061-92fce74b00bd":{"role":"admin"},"9c7dd0d4-5b44-4811-b167-e52df21092d8":{"role":"standard"}}

# App registration service principal → admin (for client_credentials tokens)
ENTRA_PRINCIPAL_TO_ROLE_JSON={"b726558d-f1c6-48f7-8a3d-72d5db818d0f":"admin"}

# JWKS endpoint (auto-derived from ENTRA_EXPECTED_TENANT_ID if omitted, but explicit is safer)
ENTRA_JWKS_URI=https://login.microsoftonline.com/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/discovery/v2.0/keys
ENTRA_OIDC_DISCOVERY_URL=https://login.microsoftonline.com/1384b1c5-2bae-45a1-a4b4-e94e3315eb41/v2.0/.well-known/openid-configuration

# ── Ledger anchoring ──────────────────────────────────────────────
LEDGER_APPEND_ENABLED=true
LEDGER_FREEZE=false
LEDGER_TAIL_MAX=200
