VITE_API_BASE=http://localhost:3001

# ── Entra ID OIDC ──────────────────────────
VITE_ENTRA_CLIENT_ID=your-entra-client-id
VITE_ENTRA_TENANT_ID=your-entra-tenant-id
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# Group OID → DIIaC role mapping
# Admins group  → admin   (full UI + dashboard + all functions)
# Standard Users group → standard (main UI, no dashboard/admin controls)
VITE_ENTRA_GROUP_MAP={"your-admin-group-oid":{"role":"admin"},"your-standard-group-oid":{"role":"standard"}}
