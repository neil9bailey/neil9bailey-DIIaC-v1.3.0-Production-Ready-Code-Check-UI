# Copy this file to Frontend/.env for local development.
# These values are public (app registration identifiers, not secrets).
VITE_API_BASE=http://localhost:3001

# ── Entra ID OIDC Authentication (MSAL) ─────────────────────────
# When VITE_ENTRA_CLIENT_ID is set, MSAL redirect auth is enabled.
# When unset/empty, the app falls back to legacy role-selector dev mode.
VITE_ENTRA_CLIENT_ID=b726558d-f1c6-48f7-8a3d-72d5db818d0f
VITE_ENTRA_TENANT_ID=1384b1c5-2bae-45a1-a4b4-e94e3315eb41
VITE_ENTRA_REDIRECT_URI=http://localhost:5173/auth/callback

# ── Entra Group → DIIaC Role Mapping ────────────────────────────
# JSON object: { "<group-object-id>": { "role": "admin"|"standard", "subrole": "cto"|"ciso"|... } }
VITE_ENTRA_GROUP_MAP={"81786818-de16-4115-b061-92fce74b00bd":{"role":"admin"},"9c7dd0d4-5b44-4811-b167-e52df21092d8":{"role":"standard"}}
